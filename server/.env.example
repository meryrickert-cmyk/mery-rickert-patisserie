# Puerto (Railway lo setea automáticamente — no tocar en producción)
PORT=5001

# Secreto para JWT — cambiá esto por una cadena larga y aleatoria en producción
JWT_SECRET=tu_secreto_muy_largo_y_seguro_aqui

# Directorio de datos persistentes
# En Railway: apunta al volumen montado (ej: /data)
# En local: dejalo vacío — usa server/ por defecto
DATA_DIR=

# WhatsApp destino para pedidos
WHATSAPP_DESTINO=5491164936089

# Entorno
NODE_ENV=production
